# OpenAI (or compatible API)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Trading
EXCHANGE_ID=binance
SYMBOL=BTC/USDT
TIMEFRAME=1h
CANDLE_HISTORY=50
STARTING_BALANCE=10000

# Trading style (LLM risk/sizing rules). Use a file path or inline text (inline wins).
TRADING_STYLE_PROMPT_PATH=prompts/trading_style.txt
# TRADING_STYLE_PROMPT=You are a systematic crypto trader...

# Modes: backtest uses CSV; paper/live use ccxt
CCXT_API_KEY=
CCXT_API_SECRET=
CCXT_SANDBOX=true
